<Window x:Class="Calculator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Calculator.App.ViewModels"
        mc:Ignorable="d"
        Title="Calculator" Height="500" Width="320"
        ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen"
        Background="#FF1E1E1E">

    <d:Window.DataContext>
        <vm:CalculatorViewModel />
    </d:Window.DataContext>

    <Window.Resources>
        <!-- Number button style -->
        <Style x:Key="NumButton" TargetType="Button">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Background" Value="#FF3B3B3B" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF4F4F4F" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF5A5A5A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Operator button style -->
        <Style x:Key="OpButton" TargetType="Button" BasedOn="{StaticResource NumButton}">
            <Setter Property="Background" Value="#FF005A9E" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF0078D4" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF0090FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Function button style (C, CE, Backspace, Negate) -->
        <Style x:Key="FuncButton" TargetType="Button" BasedOn="{StaticResource NumButton}">
            <Setter Property="Background" Value="#FF2D2D2D" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF3D3D3D" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF4D4D4D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Expression display -->
        <TextBlock Grid.Row="0" Text="{Binding Expression}"
                   FontSize="14" Foreground="Gray"
                   HorizontalAlignment="Right" Margin="8,12,8,0"
                   TextTrimming="CharacterEllipsis" />

        <!-- Main display -->
        <TextBlock Grid.Row="1" Text="{Binding Display}"
                   FontSize="40" FontWeight="Light" Foreground="White"
                   HorizontalAlignment="Right" Margin="8,4,8,12"
                   TextTrimming="CharacterEllipsis" />

        <!-- Button grid -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Row 0: %, CE, C, Backspace -->
            <Button Grid.Row="0" Grid.Column="0" Content="%" Style="{StaticResource FuncButton}"
                    Command="{Binding OperatorCommand}" CommandParameter="%" />
            <Button Grid.Row="0" Grid.Column="1" Content="CE" Style="{StaticResource FuncButton}"
                    Command="{Binding ClearEntryCommand}" />
            <Button Grid.Row="0" Grid.Column="2" Content="C" Style="{StaticResource FuncButton}"
                    Command="{Binding ClearCommand}" />
            <Button Grid.Row="0" Grid.Column="3" Content="⌫" Style="{StaticResource FuncButton}"
                    Command="{Binding BackspaceCommand}" />

            <!-- Row 1: 7, 8, 9, ÷ -->
            <Button Grid.Row="1" Grid.Column="0" Content="7" Style="{StaticResource NumButton}"
                    Command="{Binding DigitCommand}" CommandParameter="7" />
            <Button Grid.Row="1" Grid.Column="1" Content="8" Style="{StaticResource NumButton}"
                    Command="{Binding DigitCommand}" CommandParameter="8" />
            <Button Grid.Row="1" Grid.Column="2" Content="9" Style="{StaticResource NumButton}"
                    Command="{Binding DigitCommand}" CommandParameter="9" />
            <Button Grid.Row="1" Grid.Column="3" Content="÷" Style="{StaticResource OpButton}"
                    Command="{Binding OperatorCommand}" CommandParameter="÷" />

            <!-- Row 2: 4, 5, 6, × -->
            <Button Grid.Row="2" Grid.Column="0" Content="4" Style="{StaticResource NumButton}"
                    Command="{Binding DigitCommand}" CommandParameter="4" />
            <Button Grid.Row="2" Grid.Column="1" Content="5" Style="{StaticResource NumButton}"
                    Command="{Binding DigitCommand}" CommandParameter="5" />
            <Button Grid.Row="2" Grid.Column="2" Content="6" Style="{StaticResource NumButton}"
                    Command="{Binding DigitCommand}" CommandParameter="6" />
            <Button Grid.Row="2" Grid.Column="3" Content="×" Style="{StaticResource OpButton}"
                    Command="{Binding OperatorCommand}" CommandParameter="×" />

            <!-- Row 3: 1, 2, 3, - -->
            <Button Grid.Row="3" Grid.Column="0" Content="1" Style="{StaticResource NumButton}"
                    Command="{Binding DigitCommand}" CommandParameter="1" />
            <Button Grid.Row="3" Grid.Column="1" Content="2" Style="{StaticResource NumButton}"
                    Command="{Binding DigitCommand}" CommandParameter="2" />
            <Button Grid.Row="3" Grid.Column="2" Content="3" Style="{StaticResource NumButton}"
                    Command="{Binding DigitCommand}" CommandParameter="3" />
            <Button Grid.Row="3" Grid.Column="3" Content="-" Style="{StaticResource OpButton}"
                    Command="{Binding OperatorCommand}" CommandParameter="-" />

            <!-- Row 4: +/-, 0, ., + -->
            <Button Grid.Row="4" Grid.Column="0" Content="+/-" Style="{StaticResource FuncButton}"
                    Command="{Binding NegateCommand}" />
            <Button Grid.Row="4" Grid.Column="1" Content="0" Style="{StaticResource NumButton}"
                    Command="{Binding DigitCommand}" CommandParameter="0" />
            <Button Grid.Row="4" Grid.Column="2" Content="." Style="{StaticResource NumButton}"
                    Command="{Binding DecimalCommand}" />
            <Button Grid.Row="4" Grid.Column="3" Content="+" Style="{StaticResource OpButton}"
                    Command="{Binding OperatorCommand}" CommandParameter="+" />

            <!-- Row 5: Equals -->
            <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="4" Content="=" Style="{StaticResource OpButton}"
                    FontSize="24" Command="{Binding EqualsCommand}" />
        </Grid>
    </Grid>
</Window>
